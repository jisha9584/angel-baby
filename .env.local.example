# ─────────────────────────────────────────────────────────────
#  Supabase — copy this file to .env.local and fill in values
# ─────────────────────────────────────────────────────────────

# Found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Found in: Supabase Dashboard → Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Found in: Supabase Dashboard → Settings → API → service_role key
# ⚠️  Keep this secret — used only in server actions, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
